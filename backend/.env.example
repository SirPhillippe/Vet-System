# Copy this file to backend/.env and fill in your own values.
# Do NOT commit the real .env — it contains secrets.

# Server
PORT=5000
NODE_ENV=development

# Auth — use a long random string
JWT_SECRET=replace-with-a-long-random-secret

# Database (MySQL)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=vet_management

# Email — Gmail / Nodemailer (optional, for notification emails)
# Use a Gmail App Password, not your account password.
EMAIL_USER=your-email@gmail.com
EMAIL_APP_PASSWORD=your-gmail-app-password
APP_BASE_URL=http://localhost:5000

# Email — SMTP alternative (optional, used by utils/email.js)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Pawfect Care <no-reply@example.com>"

# Stripe payments (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
